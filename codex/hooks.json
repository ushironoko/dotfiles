{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/pre_tool_use/npm_script_preference.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/pre_tool_use/bit_command_policy.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/permission_request/asuku.sh\"",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|ApplyPatch|Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/post_tool_use/coding_cycle.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/post_tool_use/type_safety_check.sh\"",
            "timeout": 10,
            "statusMessage": "Checking type safety..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/session_start/statusline_checks.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/user_prompt_submit/ultracode_context.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/stop/statusline_checks.sh\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.codex/hooks/stop/asuku_notification.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
