# codex/config.toml is a live file that codex rewrites at runtime, filling it
# with machine-local state — absolute paths in [projects.*] trust (incl. client
# repos), [mcp_servers.*] (Codex.app paths), [marketplaces.*] sources, notify,
# [desktop...perPath], and [hooks.state] approval hashes. The codex-scrub clean
# filter drops anything holding a quoted absolute path, every
# [projects.*]/[mcp_servers.*] table, and the complete [hooks.state] tree at
# `git add` time. Driver is defined per-checkout by scripts/setup-git-filters.sh
# (wired into `bun run run-all`).
codex/config.toml filter=codex-scrub
