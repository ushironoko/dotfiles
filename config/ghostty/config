# Ghostty Configuration

# https://ghostty.org/docs/config

# Theme (light:dark format for automatic switching)

theme = light:Catppuccin Latte,dark:Arcoiris
background-opacity = 1
background = 1c1918

# Font

font-family = Osaka
font-size = 15
font-thicken = true

# Window

window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-save-state = always
window-inherit-working-directory = true

# Cursor

cursor-style = block
cursor-style-blink = true

# Shell

shell-integration = detect
copy-on-select = clipboard

# Behavior
# 
quit-after-last-window-closed = true
keybind = global:shift+escape=toggle_visibility

# Quick Terminal (Quake-style drop-down terminal)
# Cmd+T to toggle quick terminal from anywhere
keybind = global:super+t=toggle_quick_terminal
quick-terminal-position = bottom
quick-terminal-size = 90%
quick-terminal-animation-duration = 0.1
quick-terminal-autohide = true
quick-terminal-keyboard-interactivity = none

# macos
macos-titlebar-style = tabs
macos-option-as-alt = true

# Disable default fullscreen toggle (Cmd+Enter)
keybind = super+enter=unbind

# Helix補完用
keybind = alt+i=unbind

# スプリット移動
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom

# 行頭・行末移動 (Cmd+左右 → Home/End)
keybind = super+left=text:\x1b[H
keybind = super+right=text:\x1b[F
