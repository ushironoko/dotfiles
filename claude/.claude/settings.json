{
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(mise:*)",
      "Bash(codex login status:*)",
      "Bash(~/.claude/hooks/lib/codex-stage.sh:*)",
      "Bash(bit issue init:*)",
      "Bash(bit issue create:*)",
      "Bash(bit issue list:*)",
      "Bash(bit issue view:*)",
      "Bash(bit issue get:*)",
      "Bash(bit issue update:*)",
      "Bash(bit issue close:*)",
      "Bash(bit issue reopen:*)",
      "Bash(bit issue comment:*)",
      "Bash(bit issue search:*)",
      "Read(**)",
      "Read(~/.bashrc)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(bit issue claim:*)",
      "Bash(bit issue unclaim:*)",
      "Bash(bit issue claims:*)",
      "Bash(bit issue watch:*)",
      "Bash(bit issue import:*)",
      "Bash(bit pr import:*)",
      "Bash(bit relay:*)",
      "Bash(bit clone relay+*)"
    ],
    "defaultMode": "auto"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/asuku.app/Contents/MacOS/asuku-hook notification",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/Applications/asuku.app/Contents/MacOS/asuku-hook permission-request",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".js\") or endswith(\".ts\"))' | ~/.claude/hooks/post_tool_use/coding_cycle.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/post_tool_use/type_safety_check.sh",
            "timeout": 10,
            "statusMessage": "Checking type safety..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Workflow",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre_tool_use/codex_stage_guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre_tool_use/npm_script_preference.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session_start/statusline_checks.sh",
            "timeout": 600,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/stop/statusline_checks.sh",
            "timeout": 600,
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/task-completed/bit-issue-update.sh",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/user_prompt_submit/ultracode_codex_context.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree/create.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree/remove.sh",
            "timeout": 15
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "'/Users/ushironoko/Library/Application Support/QuotaGlance/statusline-bridge.sh' --tee | '/Applications/asuku.app/Contents/MacOS/asuku-hook' statusline | ~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "plansDirectory": "./plans",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "verbose": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "model": "claude-fable-5[1m]"
}
