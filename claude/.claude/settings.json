{
  "agentPushNotifEnabled": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "async": true,
            "command": "\/Applications\/asuku.app\/Contents\/MacOS\/asuku-hook notification",
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "\/Applications\/asuku.app\/Contents\/MacOS\/asuku-hook permission-request",
            "timeout": 300,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "jq -r '.tool_input.file_path | select(endswith(\".js\") or endswith(\".ts\"))' | ~\/.claude\/hooks\/post_tool_use\/coding_cycle.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": "~\/.claude\/hooks\/post_tool_use\/type_safety_check.sh",
            "statusMessage": "Checking type safety...",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "~\/.claude\/hooks\/pre_tool_use\/codex_stage_guard.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Workflow"
      },
      {
        "hooks": [
          {
            "command": "~\/.claude\/hooks\/pre_tool_use\/npm_script_preference.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~\/.claude\/hooks\/session_start\/statusline_checks.sh",
            "timeout": 600,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~\/.claude\/hooks\/stop\/statusline_checks.sh",
            "timeout": 600,
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "async": true,
            "command": "~\/.claude\/hooks\/task-completed\/bit-issue-update.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "~\/.claude\/hooks\/user_prompt_submit\/ultracode_codex_context.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": ".*"
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "~\/.claude\/hooks\/worktree\/create.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "~\/.claude\/hooks\/worktree\/remove.sh",
            "timeout": 15,
            "type": "command"
          }
        ]
      }
    ]
  },
  "language": "Japanese",
  "permissions": {
    "allow": [
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(cargo:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(mise:*)",
      "Bash(codex login status:*)",
      "Bash(~\/.claude\/hooks\/lib\/codex-stage.sh:*)",
      "Bash(bit issue init:*)",
      "Bash(bit issue create:*)",
      "Bash(bit issue list:*)",
      "Bash(bit issue view:*)",
      "Bash(bit issue get:*)",
      "Bash(bit issue update:*)",
      "Bash(bit issue close:*)",
      "Bash(bit issue reopen:*)",
      "Bash(bit issue comment:*)",
      "Bash(bit issue search:*)",
      "Read(**)",
      "Read(~\/.bashrc)",
      "Read(~\/.zshrc)",
      "mcp__mcpdoc"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(bit issue claim:*)",
      "Bash(bit issue unclaim:*)",
      "Bash(bit issue claims:*)",
      "Bash(bit issue watch:*)",
      "Bash(bit issue import:*)",
      "Bash(bit pr import:*)",
      "Bash(bit relay:*)",
      "Bash(bit clone relay+*)"
    ]
  },
  "plansDirectory": ".\/plans",
  "remoteControlAtStartup": true,
  "skipAutoPermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "statusLine": {
    "command": "'\/Users\/ushironoko\/Library\/Application Support\/QuotaGlance\/statusline-bridge.sh' --tee | '\/Applications\/asuku.app\/Contents\/MacOS\/asuku-hook' statusline | ~\/.claude\/statusline.sh",
    "padding": 0,
    "type": "command"
  },
  "verbose": true
}
